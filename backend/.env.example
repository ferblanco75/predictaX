# ======================================
# PREDICTAX BACKEND - ENVIRONMENT VARIABLES
# ======================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# ------------------------------
# App Configuration
# ------------------------------
APP_NAME=PredictaX API
DEBUG=false

# ------------------------------
# Database (PostgreSQL)
# ------------------------------
# Local development
DATABASE_URL=postgresql://predictax:password@localhost:5432/predictax

# Render.com (will be auto-configured)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Database Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ------------------------------
# Security & JWT
# ------------------------------
# Generate a strong secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------
# CORS Origins
# ------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://neuropredict.app,https://www.neuropredict.app

# ------------------------------
# Redis
# ------------------------------
# Local development
REDIS_URL=redis://localhost:6379/0

# Render.com Redis
# REDIS_URL=redis://host:port

# ------------------------------
# AI - Google Gemini
# ------------------------------
# Get your free API key at: https://aistudio.google.com/apikey
# Free tier: 10 RPM, 250 RPD, 250K TPM, 1M context window
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------
# Render.com Detection
# ------------------------------
# Auto-set by Render.com
RENDER=false
